  'SNYK-JS-LODASH-15869625':
    - '* > lodash':
        reason: 'Arbitrary Code Injection via _.template() in lodash@4.17.21. Lodash 4.18.0 (the Snyk-reported fix) is a deprecated bad release that breaks html-webpack-plugin. No valid fix exists on npm. The _.template() function is only invoked at build-time by html-webpack-plugin/docusaurus with trusted internal templates, not with user-controlled input. Not exploitable in current usage.'
        expires: '2027-04-01T00:00:00.000Z'
        created: '2026-04-01T00:00:00.000Z'
