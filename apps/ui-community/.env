# These :1355 URLs are examples for the non-privileged proxy mode.
# The repository's canonical commands: `pnpm proxy:start` (starts portless with -p 1355) and `pnpm proxy:stop` (port-agnostic).
NODE_ENV=development
VITE_AAD_B2C_ACCOUNT_AUTHORITY=https://mock-auth.ownercommunity.localhost:1355/community
VITE_AAD_B2C_ACCOUNT_CLIENTID=mock-client
VITE_AAD_B2C_REDIRECT_URI=https://ownercommunity.localhost:1355/auth-redirect
VITE_AAD_B2C_ACCOUNT_SCOPES=openid
VITE_FUNCTION_ENDPOINT=https://data-access.ownercommunity.localhost:1355/api/graphql
