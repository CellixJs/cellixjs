{
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": ["^build"],
			"persistent": true,
			"interruptible": false,
			"inputs": [".env", "package.json", "vite.config.ts", "tsconfig.json", "tsconfig.app.json", "tsconfig.node.json"]
		},
		"dev:portless": {
			"dependsOn": ["^build"],
			"persistent": true,
			"interruptible": false,
			"inputs": [".env", "package.json", "start-dev.mjs", "vite.config.ts", "tsconfig.json", "tsconfig.app.json", "tsconfig.node.json"]
		}
	}
}
