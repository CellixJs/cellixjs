{
	"extends": "@cellix/typescript-config/base",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
		"jsx": "react-jsx",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"exactOptionalPropertyTypes": false,
		"skipLibCheck": true
	},
	"include": ["src"]
}
