{
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": [],
			"persistent": true,
			"interruptible": false,
			"inputs": [".env", "package.json", "start-dev.mjs", "docusaurus.config.ts", "sidebars.ts", "tsconfig.json"]
		},
		"test": {
			"inputs": ["$TURBO_EXTENDS$", "!docs/**", "!blog/**", "!static/**"]
		},
		"test:coverage": {
			"inputs": ["$TURBO_EXTENDS$", "!docs/**", "!blog/**", "!static/**"]
		},
		"test:watch": {
			"cache": false,
			"persistent": true,
			"inputs": ["$TURBO_EXTENDS$", "!docs/**", "!blog/**", "!static/**"]
		},
		"lint": {
			"inputs": ["$TURBO_EXTENDS$", "!static/**", "!**/*.md"]
		}
	}
}
