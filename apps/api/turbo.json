{
	"extends": ["//"],
	"tasks": {
		"build": {
			"cache": true,
			"dependsOn": ["^build", "//#gen"],
			"inputs": ["$TURBO_EXTENDS$", "rolldown.config.ts", "host.json", "$TURBO_ROOT$/build-pipeline/scripts/**"],
			"outputs": ["$TURBO_EXTENDS$", "deploy/**"]
		},
		"dev": {
			"dependsOn": ["^build", "build", "//#gen"],
			"interruptible": true,
			"inputs": []
		}
	}
}
