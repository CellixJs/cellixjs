{
	"name": "@ocom/domain",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"format": "biome format --write",
		"prebuild": "pnpm run lint && pnpm run format",
		"build": "tsc --build",
		"watch": "tsc --watch",
		"test": "vitest run --silent --reporter=dot",
		"test:coverage": "vitest run --coverage --silent --reporter=dot",
		"test:integration": "vitest run integration.test.ts --silent --reporter=dot",
		"test:serenity": "cucumber-js",
		"test:unit": "vitest run --exclude tests/integration/**/*.test.ts --silent --reporter=dot",
		"test:watch": "vitest",
		"lint": "biome lint",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@cellix/domain-seedwork": "workspace:*",
		"@cellix/event-bus-seedwork-node": "workspace:*",
		"@lucaspaganini/value-objects": "^1.3.1"
	},
	"devDependencies": {
		"@cellix/config-typescript": "workspace:*",
		"@cellix/config-vitest": "workspace:*",
		"@cucumber/cucumber": "^11.3.0",
		"@cucumber/node": "^0.4.0",
		"@cucumber/pretty-formatter": "^1.0.1",
		"@serenity-js/assertions": "^3.32.3",
		"@serenity-js/console-reporter": "^3.32.3",
		"@serenity-js/core": "^3.32.3",
		"@serenity-js/cucumber": "^3.32.3",
		"@serenity-js/serenity-bdd": "^3.32.3",
		"@vitest/coverage-istanbul": "catalog:",
		"rimraf": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
