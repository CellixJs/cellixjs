{
	"extends": "@cellix/config-typescript/base",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"jsx": "react-jsx",
		"lib": ["ES2023", "DOM"],
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["vite/client"]
	},
	"include": ["components/**/*.ts", "components/**/*.tsx", "components/**/*.d.ts"],
	"exclude": ["components/**/*.stories.ts", "components/**/*.stories.tsx", "components/**/*.test.ts", "components/**/*.test.tsx"]
}
