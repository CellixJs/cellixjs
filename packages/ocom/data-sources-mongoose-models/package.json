	"scripts": {
		"lint": "biome lint",
		"format": "biome format --write",
		"prebuild": "pnpm run lint && pnpm run format",
		"build": "tsc --build",
		"watch": "tsc --build --watch",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@cellix/mongoose-seedwork": "workspace:*",
		"mongoose": "catalog:"
