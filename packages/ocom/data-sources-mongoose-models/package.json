			"types": "./dist/models/member/member.model.d.ts",
			"default": "./dist/models/member/member.model.js"
		},
		"./user/end-user": {
			"types": "./dist/models/user/end-user.model.d.ts",
			"default": "./dist/models/user/end-user.model.js"
		},
		"./user/staff-user": {
			"types": "./dist/models/user/staff-user.model.d.ts",
			"default": "./dist/models/user/staff-user.model.js"
		},
		"./user/vendor-user": {
			"types": "./dist/models/user/vendor-user.model.d.ts",
			"default": "./dist/models/user/vendor-user.model.js"
		},
		"./role/end-user-role": {
			"types": "./dist/models/role/end-user-role.model.d.ts",
			"default": "./dist/models/role/end-user-role.model.js"
		},
		"./role/staff-role": {
			"types": "./dist/models/role/staff-role.model.d.ts",
