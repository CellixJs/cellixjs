{
	"name": "@ocom/service-token-validation",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
