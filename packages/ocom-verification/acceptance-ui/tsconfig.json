{
	"extends": "@cellix/config-typescript/node",
	"compilerOptions": {
		"jsx": "react-jsx",
		"erasableSyntaxOnly": false,
		"composite": false,
		"incremental": false,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"noEmit": true,
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"rootDir": "../..",
		"outDir": "./dist"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
