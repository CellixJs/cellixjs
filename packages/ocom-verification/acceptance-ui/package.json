		"@serenity-js/cucumber": "catalog:",
		"@serenity-js/console-reporter": "catalog:",
		"@serenity-js/serenity-bdd": "catalog:",
		"std-env": "^4.0.0"
	},
	"devDependencies": {
		"@cellix/config-typescript": "workspace:*",
		"@ocom-verification/verification-shared": "workspace:*",
		"@testing-library/react": "^16.3.0",
		"@types/node": "catalog:",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"c8": "^10.1.3",
		"jsdom": "^26.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tsx": "^4.20.3",
		"typescript": "catalog:"
	}
