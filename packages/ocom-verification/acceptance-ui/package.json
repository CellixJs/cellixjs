{
	"name": "@ocom-verification/acceptance-ui",
	"version": "1.0.0",
	"description": "Acceptance tests for the CellixJS Community UI — renders components with jsdom + Serenity/JS + Cucumber",
	"private": true,
	"type": "module",
	"scripts": {
		"test:acceptance": "LOG_LEVEL=warn NODE_OPTIONS='--import tsx/esm' cucumber-js",
