{
	"extends": ["//"],
	"tasks": {
		"test:e2e": {
			"dependsOn": ["^build"],
			"inputs": [
				"src/**/*.ts",
				"config/**",
				"$TURBO_ROOT$/apps/api/local-settings.e2e.json",
				"$TURBO_ROOT$/apps/ui-community/.env.e2e",
				"$TURBO_ROOT$/apps/ui-staff/.env.e2e",
				"$TURBO_ROOT$/packages/cellix/local-dev/src/**",
				"cucumber.js",
				"package.json"
			],
			"cache": false
		},
		"test:e2e:ci": {
			"dependsOn": ["^build"],
			"inputs": ["src/**/*.ts", "cucumber.js", "package.json"],
			"cache": false
		},
		"test:serenity": {
			"dependsOn": ["^build"],
			"inputs": [
				"src/**/*.ts",
				"config/**",
				"$TURBO_ROOT$/apps/api/local-settings.e2e.json",
				"$TURBO_ROOT$/apps/ui-community/.env.e2e",
				"$TURBO_ROOT$/apps/ui-staff/.env.e2e",
				"$TURBO_ROOT$/packages/cellix/local-dev/src/**",
				"cucumber.js",
				"package.json"
			],
			"cache": false
		}
	}
}
