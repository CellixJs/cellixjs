{
	"name": "@cellix/server-oauth2-mock-seedwork",
	"version": "1.0.0",
	"author": "",
	"description": "Reusable OAuth2/OIDC mock server seedwork for local development and testing",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"prebuild": "pnpm run lint",
		"build": "tsc --build",
		"clean": "rimraf dist tsconfig.tsbuildinfo && tsc --build --clean",
		"lint": "biome lint",
		"format": "biome format --write",
		"format:check": "biome format .",
		"test": "vitest run --silent --reporter=dot",
		"test:coverage": "vitest run --coverage --silent --reporter=dot",
		"test:watch": "vitest"
	},
	"dependencies": {
		"express": "^4.22.0",
		"express-rate-limit": "^8.3.2",
		"jose": "^5.9.6"
	},
	"devDependencies": {
		"@cellix/config-typescript": "workspace:*",
		"@cellix/config-vitest": "workspace:*",
		"@vitest/coverage-istanbul": "catalog:",
		"@types/express": "^5.0.3",
		"rimraf": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
