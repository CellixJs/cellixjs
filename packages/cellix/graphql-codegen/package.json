{
	"name": "@cellix/graphql-codegen",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Cellix graphql-codegen plugins and schema builder — generates static type-def arrays and resolver manifests, and provides buildCellixSchema for consuming the generated artifacts at runtime",
	"files": [
		"dist",
		"plugins"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./plugins/static-type-defs": "./plugins/static-type-defs-plugin.mjs",
		"./plugins/resolver-manifest": "./plugins/resolver-manifest-plugin.mjs"
	},
	"scripts": {
		"lint": "biome lint",
		"format": "biome format --write",
		"prebuild": "pnpm run lint && pnpm run format",
		"build": "tsc --build",
		"watch": "tsc --watch",
		"test": "vitest run --silent --reporter=dot",
		"test:coverage": "vitest run --coverage --silent --reporter=dot",
		"test:watch": "vitest",
		"clean": "rimraf dist node_modules .turbo .coverage"
	},
	"dependencies": {
		"@cellix/graphql-core": "workspace:*",
		"@graphql-tools/merge": "^9.1.1",
		"@graphql-tools/schema": "^10.0.25",
		"@graphql-tools/utils": "^10.0.13",
		"graphql": "^16.10.0",
		"graphql-scalars": "^1.24.2"
	},
	"devDependencies": {
		"@amiceli/vitest-cucumber": "^6.3.0",
		"@cellix/config-typescript": "workspace:*",
		"@cellix/config-vitest": "workspace:*",
		"@vitest/coverage-istanbul": "catalog:",
		"rimraf": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
